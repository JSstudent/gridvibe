{
  "copilot": {
    "label": "copilot",
    "display_name": "GitHub Copilot CLI",
    "binary": "copilot",
    "environments": {
      "windows_native": {
        "supported": true,
        "recommended": true,
        "warning": "GitHub documents npm as an alternative, but npm installs require Node.js 22 or later and PowerShell 6 or higher.",
        "install_options": [
          {
            "label": "WinGet",
            "command": "winget install GitHub.Copilot",
            "requires": [
              {
                "kind": "command",
                "binary": "winget",
                "message": "WinGet is required for the preferred Windows install path."
              }
            ]
          },
          {
            "label": "npm fallback",
            "command": "npm install -g @github/copilot",
            "requires": [
              {
                "kind": "command",
                "binary": "npm",
                "message": "npm is required for the fallback install path."
              }
            ]
          }
        ]
      },
      "wsl_linux": {
        "supported": true,
        "recommended": true,
        "warning": "CLI usage still depends on account entitlement and org policy.",
        "install_options": [
          {
            "label": "npm",
            "command": "npm install -g @github/copilot",
            "requires": [
              {
                "kind": "command",
                "binary": "npm",
                "message": "npm is required for the Linux or WSL install path."
              }
            ]
          }
        ]
      },
      "ssh": {
        "supported": true,
        "recommended": false,
        "detect_only": true,
        "warning": "Remote SSH targets are detect-only by default.",
        "install_options": [
          {
            "label": "Manual remote install",
            "command": "npm install -g @github/copilot",
            "manual_only": true
          }
        ]
      }
    },
    "verify": [
      "copilot --version"
    ],
    "post_install": "Run copilot and complete /login if prompted."
  },
