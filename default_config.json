{
  "server": {
    "host": "127.0.0.1",
    "port": 5050,
    "debug": false
  },
  "ssh": {
    "default_username": "root",
    "default_port": 22,
    "connection_timeout": 30,
    "keepalive_interval": 60
  },
  "terminal": {
    "max_sessions": 8,
    "default_rows": 24,
    "default_cols": 80,
    "font_family": "Consolas, Monaco, 'Courier New', monospace",
    "font_size": 14
  },
  "security": {
    "cors_origins": [
      "*"
    ]
  },
  "appearance": {
    "theme": "system"
  },
  "voice_input": {
    "enabled": true,
    "engine": "whisper",
    "vosk_service_url": "ws://localhost:2700",
    "vosk_service_port": 2700,
    "vosk_model": "vosk-model-en-us-0.22",
    "whisper_model": "base",
    "whisper_device": "cpu",
    "whisper_compute_type": "int8",
    "language": "en-US"
  }
}
